get () {
	downloadsFolder="/home/$USER/Downloads/" 
	fileD=$(ls -Art $downloadsFolder | tail -n 1) 
	mv "$downloadsFolder/$fileD" .
	echo "[+] Getting: $fileD"
}

mkws () {
